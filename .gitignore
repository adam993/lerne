# Dependencies
node_modules/

# local-claude-files is committed by exception (project convention).
!local-claude-files/

# Yarn 4 caches & runtime — but we DO commit .yarn/releases/ and .yarnrc.yml
# so the project bootstraps without corepack network access.
.yarn/*
!.yarn/releases
!.yarn/patches
!.yarn/plugins
.yarn/install-state.gz
.pnp.*

# Build output
dist/
release/

# Capacitor native projects (regenerated by build scripts)
android/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated by scripts/version.cjs from version.json — committed file is
# version.json, not the JS/TS view of it. Avoids per-build noise in diffs.
src/version.js
src/version.ts

# Local environment
.env
.env.local

# Wireless ADB target used by `yarn build:android-adb`. Per-machine value.
.adb-device
